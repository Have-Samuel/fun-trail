<div class="min-h-screen flex bg-gray-100">

  <!-- Left Side Image -->
  <div class="hidden lg:flex lg:w-1/2">
    <%= image_tag "login.jpg",
        alt: "Login",
        class: "w-full h-full object-cover" %>
  </div>

  <!-- Right Side Login Form -->
  <div class="flex w-full lg:w-1/2 items-center justify-center px-6 py-12 bg-white">
    <div class="w-full max-w-md">

      <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">
          Welcome Back
        </h1>
        <p class="mt-2 text-gray-600">
          Sign in to your account
        </p>
      </div>

      <%= form_with url: login_path, method: :post, local: true, class: "space-y-6" do |f| %>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.email_field :email,
                class: "w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-blue-500 focus:ring focus:ring-blue-200",
                placeholder: "you@example.com" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= f.password_field :password,
                class: "w-full rounded-lg border border-gray-300 px-4 py-3 focus:border-blue-500 focus:ring focus:ring-blue-200",
                placeholder: "••••••••" %>
        </div>

        <div class="flex items-center justify-between">
          <label class="flex items-center">
            <input type="checkbox" class="rounded border-gray-300 text-blue-600">
            <span class="ml-2 text-sm text-gray-600">
              Remember me
            </span>
          </label>

          <%= link_to "Forgot password?",
              "#",
              class: "text-sm text-blue-600 hover:underline" %>
        </div>

        <%= f.submit "Sign In",
              class: "w-full rounded-lg bg-blue-600 py-3 font-semibold text-white hover:bg-blue-700 transition" %>

      <% end %>

      <p class="mt-6 text-center text-sm text-gray-600">
        Don't have an account?
        <%= link_to "Sign Up",
            signup_path,
            class: "font-semibold text-blue-600 hover:underline" %>
      </p>

    </div>
  </div>

</div>